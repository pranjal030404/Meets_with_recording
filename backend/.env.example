# MongoDB Connection
MONGODB_URI=mongodb://127.0.0.1:27017/meetclone

# JWT Secret (generate a strong random string - CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server Port
PORT=5000

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Node Environment
NODE_ENV=development

# Mediasoup SFU Configuration
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=  # Your public IP or domain (leave empty for local development)
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999

# TURN Server Configuration (Required for production)
TURN_SERVER_URL=  # e.g., turn:your-turn-server.com:3478
TURN_USERNAME=
TURN_CREDENTIAL=

# Redis Configuration (for scaling)
REDIS_URL=redis://localhost:6379

# SuperAdmin Credentials (created via npm run create-admin)
# Email: admin@meetclone.com
# Password: SuperAdmin@2026
