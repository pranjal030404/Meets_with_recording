# ============================================
# MEETCLONE - BACKEND ENVIRONMENT VARIABLES
# ============================================
# Copy this to .env and adjust for your setup
# ============================================

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=meetclone
DB_USER=adminuser
DB_PASSWORD=Admin@hellohere

# Database Connection Pool (for high-concurrency production)
DB_POOL_MAX=50
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Superadmin Credentials (used by migration & create-admin script)
SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=admin@meetclone.com
SUPERADMIN_PASSWORD=SuperAdmin@2026

# JWT Secret (generate a strong random string - CHANGE THIS IN PRODUCTION!)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server Port
PORT=5000

# Client URL (for CORS - must match your frontend URL exactly)
CLIENT_URL=http://localhost:5173

# Node Environment (development | production)
NODE_ENV=development

# ============================================
# Mediasoup SFU Configuration
# ============================================
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=  # Your public IP or domain (leave empty for local dev)
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999
MEDIASOUP_NUM_WORKERS=4  # Max workers per process (capped at 8)

# ============================================
# TURN Server Configuration (Required for production behind NAT/firewall)
# ============================================
TURN_SERVER_URL=  # e.g., turn:your-turn-server.com:3478
TURN_USERNAME=
TURN_CREDENTIAL=

# ============================================
# OpenAI Transcription Service
# ============================================
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Model options: gpt-4o-mini-transcribe (default), whisper-1
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# Default transcription language (ISO 639-1 code, e.g., en, es, fr, de)
TRANSCRIPTION_LANGUAGE=en

# ============================================
# Redis Configuration (for Socket.IO horizontal scaling)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Scaling & Production Configuration
# ============================================
# Rate limiting: max requests per minute per IP
RATE_LIMIT_MAX=100
# Enable cluster mode (forks workers across CPU cores)
CLUSTER_ENABLED=false
